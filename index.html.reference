<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Hutchinson Missionary Baptist Church — Sweet, Sweet Spirit. Montgomery, Alabama since 1900." />
  <title>Hutchinson Missionary Baptist Church — Montgomery, Alabama</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:       #0b0a08;
      --charcoal:    #161410;
      --charcoal-2:  #1e1b16;
      --cream:       #f4efe6;
      --warm-white:  #faf7f2;
      --gold:        #c49a28;
      --gold-light:  #ddb94c;
      --gold-dim:    rgba(196,154,40,0.12);
      --text-dark:   #18160e;
      --text-body:   #3b3729;
      --text-muted:  #857e6e;
      --text-light:  #c0b89e;
      --border-dark: rgba(255,255,255,0.07);
      --border-light:rgba(24,22,14,0.09);
      --section-pad: clamp(24px, 5vw, 80px);
      --nav-h: 64px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--black);
      color: var(--cream);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    body.nav-open { overflow: hidden; }

    .serif { font-family: 'Playfair Display', Georgia, serif; }

    .label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
    }

    @media (min-width: 768px) {
      .label { font-size: 10.5px; }
    }

    /* Reveal on scroll */
    .reveal {
      opacity: 0;
      transform: translateY(26px);
      transition: opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1), transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.08s; }
    .reveal-delay-2 { transition-delay: 0.16s; }
    .reveal-delay-3 { transition-delay: 0.24s; }

    /* ─────────────────── NAV ─────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      height: var(--nav-h);
      padding: 0 var(--section-pad);
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.45s ease, border-color 0.45s ease;
      border-bottom: 1px solid transparent;
    }
    nav.scrolled {
      background: rgba(11,10,8,0.96);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom-color: var(--border-dark);
    }

    .nav-logo { text-decoration: none; display: flex; flex-direction: column; gap: 1px; z-index: 210; }
    .nav-logo .mark {
      font-family: 'Playfair Display', serif;
      font-size: clamp(15px, 3.5vw, 17px);
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--cream);
      line-height: 1;
    }
    .nav-logo .sub-mark {
      font-size: 8px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .nav-links {
      display: none;
      align-items: center;
      gap: clamp(20px, 2.5vw, 32px);
      list-style: none;
    }
    .nav-links a {
      font-size: 12.5px;
      font-weight: 400;
      letter-spacing: 0.04em;
      color: rgba(244,239,230,0.65);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--cream); }

    .nav-cta {
      padding: 8px 22px;
      border: 1px solid var(--gold);
      border-radius: 100px;
      font-size: 11.5px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      transition: all 0.25s;
    }
    .nav-cta:hover { background: var(--gold); color: var(--black); }

    .nav-toggle {
      z-index: 210;
      width: 44px;
      height: 44px;
      border: 1px solid var(--border-dark);
      border-radius: 50%;
      background: rgba(22,20,16,0.6);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .nav-toggle:hover { border-color: rgba(196,154,40,0.35); }
    .nav-toggle span {
      display: block;
      width: 18px;
      height: 1.5px;
      background: var(--cream);
      border-radius: 1px;
      transition: transform 0.35s ease, opacity 0.25s ease;
    }
    body.nav-open .nav-toggle span:nth-child(1) {
      transform: translateY(6.5px) rotate(45deg);
    }
    body.nav-open .nav-toggle span:nth-child(2) { opacity: 0; }
    body.nav-open .nav-toggle span:nth-child(3) {
      transform: translateY(-6.5px) rotate(-45deg);
    }

    .nav-drawer {
      position: fixed;
      inset: 0;
      z-index: 199;
      pointer-events: none;
      visibility: hidden;
      transition: visibility 0.4s step-end;
    }
    body.nav-open .nav-drawer {
      pointer-events: auto;
      visibility: visible;
      transition: visibility 0s step-start;
    }
    .nav-drawer-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(5,4,3,0.72);
      opacity: 0;
      transition: opacity 0.4s ease;
    }
    body.nav-open .nav-drawer-backdrop { opacity: 1; }
    .nav-drawer-panel {
      position: absolute;
      top: 0;
      right: 0;
      width: min(100%, 380px);
      height: 100%;
      background: linear-gradient(165deg, #14120e 0%, var(--black) 45%);
      border-left: 1px solid rgba(196,154,40,0.12);
      box-shadow: -24px 0 80px rgba(0,0,0,0.55);
      transform: translateX(100%);
      transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
      padding: calc(var(--nav-h) + 28px) var(--section-pad) 40px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    body.nav-open .nav-drawer-panel { transform: translateX(0); }
    .nav-drawer-panel::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 40%;
      background: radial-gradient(ellipse 90% 70% at 100% 0%, rgba(196,154,40,0.14) 0%, transparent 65%);
      pointer-events: none;
    }
    .nav-drawer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 4px;
      position: relative;
      z-index: 1;
    }
    .nav-drawer-links a {
      display: block;
      padding: 16px 0;
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 400;
      color: var(--cream);
      text-decoration: none;
      border-bottom: 1px solid var(--border-dark);
      transition: color 0.2s, padding-left 0.25s ease;
    }
    .nav-drawer-links a:hover {
      color: var(--gold-light);
      padding-left: 8px;
    }
    .nav-drawer-cta {
      margin-top: 28px;
      text-align: center;
      padding: 14px 24px;
      border: 1px solid var(--gold);
      border-radius: 100px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      transition: background 0.25s, color 0.25s;
      position: relative;
      z-index: 1;
    }
    .nav-drawer-cta:hover {
      background: var(--gold);
      color: var(--black);
    }
    .nav-drawer-meta {
      margin-top: auto;
      padding-top: 32px;
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.7;
      position: relative;
      z-index: 1;
    }
    .nav-drawer-meta a { color: var(--gold-light); text-decoration: none; }
    .nav-drawer-meta a:hover { text-decoration: underline; }

    @media (min-width: 1024px) {
      .nav-toggle { display: none; }
      .nav-drawer { display: none; }
      .nav-links { display: flex; }
    }

    /* ─────────────────── HERO ─────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 var(--section-pad) clamp(72px, 12vw, 96px);
      padding-top: calc(var(--nav-h) + 24px);
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      filter: brightness(0.42) contrast(1.05);
    }
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        168deg,
        rgba(11,10,8,0.92) 0%,
        rgba(11,10,8,0.55) 38%,
        rgba(11,10,8,0.75) 100%
      );
    }

    /* Animated amber glow drift */
    .hero-amber {
      position: absolute;
      inset: -15%;
      z-index: 1;
      pointer-events: none;
      background:
        radial-gradient(ellipse 55% 70% at 78% 62%, rgba(221,185,76,0.22) 0%, transparent 55%),
        radial-gradient(ellipse 40% 50% at 20% 30%, rgba(196,154,40,0.08) 0%, transparent 50%),
        radial-gradient(ellipse 35% 45% at 92% 18%, rgba(190,130,40,0.12) 0%, transparent 48%);
      animation: amberDrift 18s ease-in-out infinite alternate;
      mix-blend-mode: screen;
      opacity: 0.85;
    }
    @keyframes amberDrift {
      0% {
        transform: translate(0, 0) scale(1);
        opacity: 0.72;
      }
      50% {
        transform: translate(-3%, 4%) scale(1.06);
        opacity: 0.92;
      }
      100% {
        transform: translate(4%, -2%) scale(1.03);
        opacity: 0.78;
      }
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 2;
      background:
        radial-gradient(ellipse 70% 90% at 80% 60%, rgba(190,118,18,0.14) 0%, transparent 60%),
        linear-gradient(165deg, rgba(15,13,10,0.4) 0%, transparent 45%);
      pointer-events: none;
    }

    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 2;
      background-image: repeating-linear-gradient(
        to right,
        rgba(196,154,40,0.028) 0px, rgba(196,154,40,0.028) 1px,
        transparent 1px, transparent 72px
      );
      pointer-events: none;
    }

    .hero-content { position: relative; z-index: 3; max-width: 820px; }

    .hero-eyebrow {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: clamp(18px, 4vw, 28px);
      flex-wrap: wrap;
    }
    .hero-eyebrow::before {
      content: '';
      display: block;
      width: clamp(24px, 6vw, 36px);
      height: 1px;
      background: var(--gold);
      flex-shrink: 0;
    }

    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.75rem, 12vw, 7.35rem);
      font-weight: 400;
      line-height: 1.02;
      letter-spacing: -0.025em;
      color: var(--cream);
      margin-bottom: clamp(24px, 5vw, 36px);
    }
    .hero-headline em {
      font-style: italic;
      color: var(--gold-light);
    }

    .hero-sub {
      font-size: clamp(15px, 3.8vw, 16.5px);
      font-weight: 300;
      color: rgba(244,239,230,0.55);
      max-width: 400px;
      line-height: 1.7;
      margin-bottom: clamp(32px, 6vw, 52px);
    }

    .hero-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    @media (min-width: 480px) {
      .hero-actions {
        flex-direction: row;
        align-items: center;
        gap: 24px;
      }
    }

    .btn-fill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 28px;
      background: var(--gold);
      border-radius: 100px;
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .btn-fill:hover {
      background: var(--gold-light);
      transform: translateY(-1px);
      box-shadow: 0 12px 32px rgba(196,154,40,0.25);
    }

    .btn-text {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
      font-weight: 400;
      color: rgba(244,239,230,0.6);
      text-decoration: none;
      transition: color 0.2s;
    }
    .btn-text:hover { color: var(--cream); }
    .btn-text .play-ring {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid rgba(244,239,230,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-text:hover .play-ring {
      border-color: rgba(244,239,230,0.5);
      background: rgba(255,255,255,0.04);
    }

    .hero-strip {
      position: relative;
      z-index: 4;
      display: flex;
      flex-direction: column;
      margin-top: clamp(40px, 8vw, 56px);
      width: 100%;
    }
    @media (min-width: 768px) {
      .hero-strip {
        position: absolute;
        bottom: 0;
        right: 0;
        flex-direction: row;
        margin-top: 0;
        width: auto;
        max-width: 100%;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
    }
    .strip-item {
      padding: 16px 24px;
      background: rgba(11,10,8,0.78);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid var(--border-dark);
      border-left: 1px solid var(--border-dark);
    }
    @media (min-width: 768px) {
      .strip-item { padding: 18px clamp(20px, 2.5vw, 36px); }
    }
    .strip-item .s-label {
      display: block;
      margin-bottom: 3px;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .strip-item .s-val {
      font-size: 12.5px;
      font-weight: 400;
      color: var(--cream);
      line-height: 1.4;
    }
    .strip-item .s-val a {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s;
    }
    .strip-item .s-val a:hover { color: var(--gold-light); }
    .strip-item .s-val.live { color: var(--gold); }

    .scroll-nudge {
      display: none;
    }
    @media (min-width: 1024px) {
      .scroll-nudge {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 4;
        opacity: 0.3;
        animation: fadeNudge 3s ease infinite;
      }
    }
    .scroll-nudge span {
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--cream);
    }
    .scroll-nudge::after {
      content: '';
      width: 1px;
      height: 44px;
      background: linear-gradient(to bottom, var(--cream), transparent);
    }
    @keyframes fadeNudge {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 0.6; }
    }

    /* ─────────────────── MISSION ─────────────────── */
    .mission {
      background: var(--warm-white);
      padding: clamp(72px, 12vw, 120px) var(--section-pad);
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(28px, 5vw, 80px);
      align-items: start;
    }
    @media (min-width: 1024px) {
      .mission {
        grid-template-columns: 220px 1fr;
      }
    }
    .mission-aside { padding-top: 4px; }
    .mission-aside .label { color: var(--text-muted); }

    .mission-quote {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.5rem, 5vw, 3.1rem);
      font-weight: 400;
      line-height: 1.22;
      letter-spacing: -0.015em;
      color: var(--text-dark);
    }
    .mission-quote em { font-style: italic; color: #8a6a10; }

    .mission-body {
      margin-top: 28px;
      font-size: 15px;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.8;
      max-width: 500px;
    }
    .mission-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 28px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-dark);
      text-decoration: none;
      border-bottom: 1px solid var(--text-dark);
      padding-bottom: 2px;
      transition: opacity 0.2s;
    }
    .mission-link:hover { opacity: 0.55; }

    /* ─────────────────── WATCH ─────────────────── */
    .watch {
      background: var(--charcoal-2);
      padding: clamp(72px, 10vw, 100px) var(--section-pad);
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(40px, 6vw, 88px);
      align-items: center;
    }
    @media (min-width: 1024px) {
      .watch { grid-template-columns: 1fr 1fr; }
    }
    .watch .label { display: block; margin-bottom: 18px; }
    .watch-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 400;
      line-height: 1.12;
      color: var(--cream);
      margin-bottom: 18px;
    }
    .watch-heading em { font-style: italic; color: var(--gold-light); }
    .watch-body {
      font-size: 15px;
      font-weight: 300;
      color: var(--text-light);
      line-height: 1.75;
      max-width: 380px;
      margin-bottom: 28px;
    }
    .arrow-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      transition: gap 0.2s;
    }
    .arrow-link:hover { gap: 16px; }

    /* Sermon card — video thumbnail */
    .sermon-card {
      position: relative;
      border-radius: 4px;
      overflow: hidden;
      aspect-ratio: 16/9;
      cursor: pointer;
      background: #0a0906;
      box-shadow:
        0 4px 24px rgba(0,0,0,0.35),
        0 0 0 1px rgba(255,255,255,0.04) inset;
      transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.45s ease;
    }
    .sermon-card:hover {
      transform: translateY(-4px) scale(1.01);
      box-shadow:
        0 24px 48px rgba(0,0,0,0.45),
        0 0 0 1px rgba(196,154,40,0.15) inset;
    }
    .sermon-card:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 4px;
    }
    .sermon-thumb {
      position: absolute;
      inset: 0;
    }
    .sermon-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.72) saturate(0.95);
      transition: filter 0.5s ease, transform 0.6s ease;
    }
    .sermon-card:hover .sermon-thumb img {
      filter: brightness(0.88) saturate(1.05);
      transform: scale(1.04);
    }
    .sermon-thumb::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(8,7,5,0.2) 0%, transparent 35%),
        linear-gradient(15deg, rgba(11,10,8,0.85) 0%, rgba(11,10,8,0.25) 45%, transparent 72%),
        radial-gradient(ellipse 90% 80% at 70% 20%, rgba(196,154,40,0.18) 0%, transparent 55%),
        radial-gradient(ellipse 60% 50% at 20% 100%, rgba(221,185,76,0.12) 0%, transparent 50%);
      transition: opacity 0.45s ease;
    }
    .sermon-card:hover .sermon-thumb::after {
      opacity: 0.92;
      background:
        linear-gradient(180deg, rgba(8,7,5,0.15) 0%, transparent 30%),
        linear-gradient(15deg, rgba(11,10,8,0.75) 0%, rgba(11,10,8,0.2) 40%, transparent 68%),
        radial-gradient(ellipse 90% 80% at 65% 18%, rgba(196,154,40,0.28) 0%, transparent 52%),
        radial-gradient(ellipse 55% 45% at 15% 95%, rgba(221,185,76,0.18) 0%, transparent 48%);
    }
    .sermon-duration {
      position: absolute;
      top: 14px;
      right: 14px;
      z-index: 4;
      padding: 5px 10px;
      border-radius: 4px;
      background: rgba(0,0,0,0.75);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--cream);
    }
    .sermon-card-center {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -58%);
      text-align: center;
      z-index: 3;
      pointer-events: none;
    }
    .series-label {
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(221,185,76,0.95);
      margin-bottom: 8px;
      text-shadow: 0 1px 12px rgba(0,0,0,0.5);
    }
    .series-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(22px, 4vw, 30px);
      font-weight: 700;
      color: var(--cream);
      line-height: 1.1;
      text-shadow: 0 2px 24px rgba(0,0,0,0.6);
    }
    .sermon-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 4;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      border: 1.5px solid rgba(244,239,230,0.45);
      background: rgba(0,0,0,0.35);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .sermon-card:hover .sermon-play {
      border-color: var(--cream);
      background: var(--gold);
      transform: translate(-50%, -50%) scale(1.08);
      box-shadow: 0 12px 40px rgba(196,154,40,0.35);
    }
    .sermon-card:hover .sermon-play svg { fill: var(--black); }
    .sermon-play svg { margin-left: 3px; transition: fill 0.25s; }
    .sermon-meta-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 16px 20px 18px;
      background: linear-gradient(
        to top,
        rgba(5,4,3,0.95) 0%,
        rgba(5,4,3,0.5) 45%,
        transparent 100%
      );
      z-index: 3;
    }
    .sermon-meta-bar .s-series {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 3px;
    }
    .sermon-meta-bar .s-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(15px, 2.5vw, 17px);
      font-weight: 600;
      color: var(--cream);
    }
    .sermon-meta-bar .s-meta {
      font-size: 11px;
      color: rgba(244,239,230,0.5);
      margin-top: 4px;
    }

    /* ─────────────────── LEGACY ─────────────────── */
    .legacy {
      background: var(--black);
      display: grid;
      grid-template-columns: 1fr;
      min-height: 0;
      border-top: 1px solid var(--border-dark);
    }
    @media (min-width: 1024px) {
      .legacy {
        grid-template-columns: 1fr 1fr;
        min-height: 620px;
      }
    }
    .legacy-visual {
      position: relative;
      overflow: hidden;
      background: #0e0c08;
      min-height: 320px;
    }
    @media (min-width: 1024px) {
      .legacy-visual { min-height: 0; }
    }
    .legacy-visual img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.5) contrast(1.08);
    }
    .legacy-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        radial-gradient(ellipse 65% 70% at 35% 65%, rgba(190,120,18,0.4) 0%, transparent 55%),
        radial-gradient(ellipse 40% 50% at 80% 20%, rgba(200,140,28,0.15) 0%, transparent 50%),
        linear-gradient(165deg, rgba(11,10,8,0.5) 0%, rgba(11,10,8,0.2) 100%);
    }
    .legacy-year-bg {
      position: absolute;
      bottom: -24px;
      left: -12px;
      z-index: 2;
      font-family: 'Playfair Display', serif;
      font-size: clamp(120px, 28vw, 230px);
      font-weight: 900;
      line-height: 1;
      color: transparent;
      -webkit-text-stroke: 1px rgba(196,154,40,0.15);
      pointer-events: none;
      user-select: none;
    }
    .legacy-visual-inner {
      position: relative;
      z-index: 2;
      height: 100%;
      min-height: 320px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px var(--section-pad);
    }
    .legacy-orb {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
    .legacy-orb .vert-line {
      width: 1px;
      height: 72px;
      background: linear-gradient(to bottom, transparent, rgba(196,154,40,0.45), transparent);
    }
    .legacy-orb .middle-text {
      padding: 14px 22px;
      border: 1px solid rgba(196,154,40,0.28);
      font-family: 'Playfair Display', serif;
      font-size: 12px;
      font-style: italic;
      color: rgba(221,185,76,0.9);
      letter-spacing: 0.08em;
      text-align: center;
      max-width: 100%;
    }

    .legacy-content {
      padding: clamp(56px, 8vw, 80px) var(--section-pad);
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-left: none;
      border-top: 1px solid var(--border-dark);
    }
    @media (min-width: 1024px) {
      .legacy-content {
        border-left: 1px solid var(--border-dark);
        border-top: none;
        padding: 80px clamp(40px, 5vw, 72px);
      }
    }
    .legacy-content .label { display: block; margin-bottom: 18px; }
    .legacy-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.65rem, 4vw, 2.65rem);
      font-weight: 400;
      line-height: 1.15;
      color: var(--cream);
      letter-spacing: -0.015em;
      margin-bottom: 20px;
    }
    .legacy-heading em { font-style: italic; color: var(--gold-light); }
    .legacy-body {
      font-size: 15px;
      font-weight: 300;
      color: var(--text-light);
      line-height: 1.78;
      max-width: 440px;
      margin-bottom: 0;
    }

    /* Timeline */
    .legacy-timeline {
      margin: clamp(32px, 5vw, 40px) 0;
      position: relative;
    }
    .timeline-track-h {
      display: none;
    }
    @media (min-width: 1024px) {
      .timeline-track-h {
        display: block;
        position: absolute;
        top: 10px;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent 0%,
          rgba(196,154,40,0.35) 8%,
          rgba(196,154,40,0.35) 92%,
          transparent 100%
        );
      }
    }
    .timeline-items {
      display: flex;
      flex-direction: column;
      gap: 0;
      position: relative;
    }
    @media (min-width: 1024px) {
      .timeline-items {
        flex-direction: row;
        justify-content: space-between;
        gap: 12px;
        padding-top: 0;
      }
    }
    .timeline-item {
      position: relative;
      padding-left: 28px;
      padding-bottom: 28px;
      border-left: 1px solid rgba(196,154,40,0.22);
    }
    .timeline-item:last-child {
      padding-bottom: 0;
      border-left-color: transparent;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: -5px;
      top: 6px;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--black);
      border: 2px solid var(--gold);
      box-shadow: 0 0 0 3px rgba(196,154,40,0.12);
    }
    @media (min-width: 1024px) {
      .timeline-item {
        flex: 1;
        min-width: 0;
        padding-left: 0;
        padding-bottom: 0;
        padding-top: 28px;
        border-left: none;
        text-align: center;
      }
      .timeline-item::before {
        left: 50%;
        top: 2px;
        transform: translateX(-50%);
      }
      .timeline-item:last-child { border-left: none; }
    }
    .timeline-year {
      font-family: 'Playfair Display', serif;
      font-size: 15px;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.04em;
      margin-bottom: 8px;
    }
    .timeline-desc {
      font-size: 13px;
      font-weight: 300;
      color: rgba(244,239,230,0.52);
      line-height: 1.6;
      max-width: 200px;
    }
    @media (min-width: 1024px) {
      .timeline-desc {
        margin: 0 auto;
        max-width: 180px;
      }
    }

    .legacy-callout {
      margin: 28px 0;
      padding: 22px 0;
      border-top: 1px solid var(--border-dark);
      border-bottom: 1px solid var(--border-dark);
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }
    .callout-year {
      font-family: 'Playfair Display', serif;
      font-size: 12.5px;
      font-weight: 700;
      color: var(--gold);
      white-space: nowrap;
      margin-top: 2px;
    }
    .callout-text {
      font-size: 13.5px;
      line-height: 1.65;
      color: rgba(244,239,230,0.52);
      font-weight: 300;
    }

    /* ─────────────────── ENGAGE ─────────────────── */
    .engage {
      background: var(--cream);
      padding: clamp(72px, 12vw, 120px) var(--section-pad);
    }
    .engage-header {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(28px, 5vw, 80px);
      align-items: end;
      margin-bottom: clamp(44px, 7vw, 68px);
    }
    @media (min-width: 1024px) {
      .engage-header { grid-template-columns: 1fr 1fr; }
    }
    .engage-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 400;
      line-height: 1.08;
      color: var(--text-dark);
      letter-spacing: -0.02em;
    }
    .engage-intro {
      font-size: 15px;
      color: var(--text-muted);
      line-height: 1.75;
      max-width: 380px;
      font-weight: 300;
    }

    .engage-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2px;
    }
    @media (min-width: 768px) {
      .engage-cards { grid-template-columns: repeat(3, 1fr); }
    }
    .e-card {
      background: #ede9e1;
      padding: clamp(36px, 6vw, 48px) clamp(28px, 4vw, 40px);
      text-decoration: none;
      display: block;
      position: relative;
      overflow: hidden;
      transition: background 0.3s ease;
    }
    .e-card:hover { background: var(--text-dark); }

    .e-card .e-num {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 32px;
      transition: color 0.3s;
    }
    .e-card:hover .e-num { color: rgba(244,239,230,0.3); }

    .e-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(26px, 4vw, 30px);
      font-weight: 500;
      color: var(--text-dark);
      line-height: 1.1;
      margin-bottom: 14px;
      transition: color 0.3s;
    }
    .e-card:hover .e-title { color: var(--cream); }

    .e-desc {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.65;
      transition: color 0.3s;
    }
    .e-card:hover .e-desc { color: rgba(244,239,230,0.55); }

    .e-arrow {
      display: block;
      margin-top: 32px;
      font-size: 20px;
      color: var(--text-dark);
      transition: color 0.3s, transform 0.25s;
    }
    .e-card:hover .e-arrow { color: var(--gold-light); transform: translateX(8px); }

    /* ─────────────────── NEW HERE ─────────────────── */
    .new-here {
      background: var(--charcoal);
      padding: clamp(72px, 12vw, 120px) var(--section-pad);
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(40px, 6vw, 88px);
      align-items: start;
    }
    @media (min-width: 1024px) {
      .new-here {
        grid-template-columns: 1fr 1fr;
        align-items: center;
      }
    }
    .new-here-right {
      display: flex;
      flex-direction: column;
      gap: clamp(28px, 4vw, 36px);
      order: -1;
    }
    @media (min-width: 1024px) {
      .new-here-right { order: 0; }
    }
    .new-here-visual {
      position: relative;
      border-radius: 4px;
      overflow: hidden;
      aspect-ratio: 4/3;
      max-height: 480px;
      box-shadow: 0 24px 60px rgba(0,0,0,0.35);
    }
    .new-here-visual img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.85) contrast(1.02);
    }
    .new-here-visual::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(196,154,40,0.12) 0%, transparent 50%);
      pointer-events: none;
    }

    .new-here .label { display: block; margin-bottom: 18px; }
    .new-here-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 400;
      line-height: 1.08;
      color: var(--cream);
      letter-spacing: -0.015em;
      margin-bottom: 22px;
    }
    .new-here-body {
      font-size: 16px;
      font-weight: 300;
      color: var(--text-light);
      line-height: 1.75;
      max-width: 400px;
      margin-bottom: 32px;
    }

    .expect-list { display: flex; flex-direction: column; gap: 2px; }
    .expect-item {
      padding: 18px 22px;
      background: rgba(255,255,255,0.03);
      border-left: 2px solid transparent;
      transition: all 0.25s;
    }
    .expect-item:hover {
      background: rgba(255,255,255,0.055);
      border-left-color: var(--gold);
    }
    .expect-title {
      font-size: 14px;
      font-weight: 500;
      color: var(--cream);
      margin-bottom: 4px;
    }
    .expect-desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.55;
    }

    /* ─────────────────── GIVE ─────────────────── */
    .give {
      background: var(--black);
      padding: clamp(88px, 14vw, 128px) var(--section-pad);
      text-align: center;
      border-top: 1px solid var(--border-dark);
    }
    .give-rule {
      width: 40px;
      height: 1px;
      background: var(--gold);
      margin: 0 auto 40px;
    }
    .give-scripture {
      font-family: 'Playfair Display', serif;
      font-size: clamp(17px, 3vw, 28px);
      font-weight: 400;
      font-style: italic;
      color: rgba(244,239,230,0.38);
      max-width: 560px;
      margin: 0 auto 12px;
      line-height: 1.55;
    }
    .give-ref {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 48px;
    }
    .give-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 7vw, 3.75rem);
      font-weight: 400;
      line-height: 1.05;
      color: var(--cream);
      letter-spacing: -0.02em;
      margin-bottom: 18px;
    }
    .give-sub {
      font-size: 15.5px;
      font-weight: 300;
      color: var(--text-muted);
      max-width: 400px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }

    /* ─────────────────── FOOTER ─────────────────── */
    footer {
      background: #080706;
      padding: clamp(48px, 8vw, 72px) var(--section-pad) 36px;
      border-top: 1px solid var(--border-dark);
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
      padding-bottom: 40px;
      border-bottom: 1px solid var(--border-dark);
      margin-bottom: 28px;
    }
    @media (min-width: 768px) {
      .footer-grid {
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: 40px;
      }
    }
    @media (min-width: 1024px) {
      .footer-grid {
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 56px;
        padding-bottom: 56px;
        margin-bottom: 36px;
      }
    }
    .footer-brand .f-name {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--cream);
      display: block;
      margin-bottom: 3px;
    }
    .footer-brand .f-sub {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      display: block;
      margin-bottom: 18px;
    }
    .footer-brand p {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 280px;
      margin-bottom: 22px;
    }
    .f-socials { display: flex; gap: 10px; flex-wrap: wrap; }
    .f-socials a {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 1px solid var(--border-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10.5px;
      color: var(--text-muted);
      text-decoration: none;
      transition: all 0.2s;
    }
    .f-socials a:hover { border-color: var(--gold); color: var(--gold); }

    .footer-col h4 {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 18px;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col a {
      font-size: 13px;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-col a:hover { color: var(--cream); }
    .footer-col address {
      font-style: normal;
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.85;
    }

    .footer-bottom {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    @media (min-width: 768px) {
      .footer-bottom {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }
    }
    .footer-copy { font-size: 12px; color: rgba(133,126,110,0.5); }
    .footer-est {
      font-family: 'Playfair Display', serif;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(133,126,110,0.3);
    }

    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .hero-amber { animation: none; opacity: 0.8; }
      .scroll-nudge { animation: none; }
    }
  </style>
</head>
<body>

  <!-- ═══ NAVIGATION ═══ -->
  <nav id="nav" aria-label="Primary">
    <a href="#" class="nav-logo">
      <span class="mark">HUTCHINSON</span>
      <span class="sub-mark">Missionary Baptist Church</span>
    </a>
    <ul class="nav-links">
      <li><a href="#new-here">New Here?</a></li>
      <li><a href="#watch">Watch</a></li>
      <li><a href="#engage">Ministries</a></li>
      <li><a href="#legacy">Our Story</a></li>
      <li><a href="https://pushpay.com/g/hutchinsonmbc" class="nav-cta" target="_blank" rel="noopener noreferrer">Give</a></li>
    </ul>
    <button type="button" class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-drawer-panel" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <div class="nav-drawer" id="nav-drawer" aria-hidden="true">
    <div class="nav-drawer-backdrop" id="nav-drawer-backdrop"></div>
    <div class="nav-drawer-panel" id="nav-drawer-panel" role="dialog" aria-modal="true" aria-label="Menu">
      <ul class="nav-drawer-links">
        <li><a href="#new-here" class="drawer-link">New Here?</a></li>
        <li><a href="#watch" class="drawer-link">Watch</a></li>
        <li><a href="#engage" class="drawer-link">Ministries</a></li>
        <li><a href="#legacy" class="drawer-link">Our Story</a></li>
        <li><a href="#give" class="drawer-link">Give</a></li>
      </ul>
      <a href="https://pushpay.com/g/hutchinsonmbc" class="nav-drawer-cta" target="_blank" rel="noopener noreferrer">Give Online</a>
      <p class="nav-drawer-meta">
        860 East Grove Street<br />
        Montgomery, AL 36104<br /><br />
        <a href="https://www.youtube.com/@hmbc860" target="_blank" rel="noopener noreferrer">YouTube @hmbc860</a>
      </p>
    </div>
  </div>

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="top" aria-label="Welcome">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1438232992991-995b671e4b8b?auto=format&amp;fit=crop&amp;w=1920&amp;q=80"
        alt="Warm light inside a historic church sanctuary"
        width="1920"
        height="1080"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="hero-amber" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span class="label">Montgomery, Alabama · Est. 1900</span>
      </div>
      <h1 class="hero-headline">
        A <em>Sweet,<br>Sweet</em> Spirit.
      </h1>
      <p class="hero-sub">
        Rooted in 125 years of faith, community, and the enduring love of God. A new season. The same spirit. You are welcome here.
      </p>
      <div class="hero-actions">
        <a href="#new-here" class="btn-fill">Join Us Sunday</a>
        <a href="https://www.youtube.com/@hmbc860" class="btn-text" target="_blank" rel="noopener noreferrer">
          <span class="play-ring">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="rgba(244,239,230,0.7)" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
          </span>
          Watch Online
        </a>
      </div>
    </div>

    <div class="hero-strip">
      <div class="strip-item">
        <span class="s-label">Sunday Service</span>
        <span class="s-val">9:00 AM &amp; 11:00 AM</span>
      </div>
      <div class="strip-item">
        <span class="s-label">Location</span>
        <span class="s-val">860 East Grove St, Montgomery, AL 36104</span>
      </div>
      <div class="strip-item">
